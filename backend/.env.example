# Database
DATABASE_URL=postgresql://user:password@localhost:5432/home_inspection

# JWT Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of allowed frontend origins
# Leave as * for local development; set to your Vercel URL in production
# e.g. https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*

# Cookie Security
# Set to false for local HTTP development, true for production HTTPS (Render/Vercel)
# Note: SameSite=None is used for cross-origin cookie auth (Vercel → Render)
# SameSite=None requires Secure=True, so always set COOKIE_SECURE=true in production
COOKIE_SECURE=false
